{
  "name": "nuxt-todo-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r --if-present run build",
    "lint": "eslint . && pnpm --filter web lint",
    "lint:fix": "eslint . --fix && pnpm --filter web lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "node --test scripts/verify-monorepo.test.mjs && node --test scripts/verify-tooling.test.mjs && node --test scripts/verify-ci.test.mjs && pnpm --filter @symb-abm/shared test && pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.35.1"
  }
}
